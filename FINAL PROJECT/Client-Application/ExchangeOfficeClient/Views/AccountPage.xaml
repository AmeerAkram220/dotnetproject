<Page x:Class="ExchangeOfficeClient.Views.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="My Account">
    <Grid Background="#F5F7FA" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtTitle" Text="My Account"
                   Style="{StaticResource PageTitle}"/>

        <!-- Top-up section -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20"
                Margin="0,0,0,16" BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Top Up PLN Balance" FontSize="15" FontWeight="SemiBold"
                           Foreground="#1E3A5F" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtTopUp" Width="160" Height="34" Padding="8,6"
                             BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                    <Button Content="Add Funds" Click="BtnTopUp_Click"
                            Style="{StaticResource PrimaryButton}" Height="34" Margin="10,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="TxtTopUpMsg" Margin="0,8,0,0"
                           Visibility="Collapsed" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="My Balances" FontSize="15" FontWeight="SemiBold"
                   Foreground="#1E3A5F" Margin="0,0,0,8"/>

        <DataGrid Grid.Row="3" x:Name="BalancesGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#F0F4F8"
                  BorderBrush="#CCCCCC" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="120"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=F2}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
