<Page x:Class="ExchangeOfficeClient.Views.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="My Account">
    <ScrollViewer Background="#F5F7FA" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- User info card -->
            <Border Background="White" CornerRadius="8" Padding="20"
                    Margin="0,0,0,16" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock x:Name="TxtUsername" FontSize="20" FontWeight="Bold" Foreground="#1E3A5F"/>
                        <TextBlock x:Name="TxtUserId" Foreground="Gray" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Top-up section -->
            <Border Background="White" CornerRadius="8" Padding="20"
                    Margin="0,0,0,16" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Top Up PLN Balance" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1E3A5F" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtTopUp" Width="160" Height="34" Padding="8,6"
                                 BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                        <Button Content="Add Funds" Click="BtnTopUp_Click"
                                Style="{StaticResource PrimaryButton}" Height="34" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtTopUpMsg" Margin="0,8,0,0"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Balances -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="My Balances" FontSize="15" FontWeight="SemiBold"
                           Foreground="#1E3A5F" VerticalAlignment="Center"/>
                <Button Content="↻ Refresh" Click="BtnRefresh_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#1E3A5F" Cursor="Hand" Margin="12,0,0,0" FontSize="13"/>
            </StackPanel>
            <DataGrid x:Name="BalancesGrid" Height="160"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" AlternatingRowBackground="#F0F4F8"
                      BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,16">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="120"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=F2}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Change password -->
            <Border Background="White" CornerRadius="8" Padding="20"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Change Password" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1E3A5F" Margin="0,0,0,12"/>
                    <TextBlock Text="Current Password" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtCurrentPwd" Height="34" Padding="8,6"
                                 BorderBrush="#CCCCCC" Margin="0,0,0,10"/>
                    <TextBlock Text="New Password (min 6 characters)" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtNewPwd" Height="34" Padding="8,6"
                                 BorderBrush="#CCCCCC" Margin="0,0,0,10"/>
                    <TextBlock Text="Confirm New Password" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtConfirmPwd" Height="34" Padding="8,6"
                                 BorderBrush="#CCCCCC" Margin="0,0,0,12"/>
                    <Button Content="Change Password" Click="BtnChangePwd_Click"
                            Style="{StaticResource PrimaryButton}" Height="36" HorizontalAlignment="Left" Width="160"/>
                    <TextBlock x:Name="TxtPwdMsg" Margin="0,8,0,0"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
