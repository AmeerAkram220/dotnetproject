<Page x:Class="ExchangeOfficeClient.Views.ExchangeRatesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Exchange Rates">
    <ScrollViewer Background="#F5F7FA" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="Exchange Rates" Style="{StaticResource PageTitle}"/>

            <!-- ── Current Rates ─────────────────────────────────────── -->
            <Border Background="White" CornerRadius="8" Padding="16"
                    BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Current Rates" FontSize="14"
                               FontWeight="SemiBold" Foreground="#1E3A5F" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="TxtSearch" Width="200" Height="34" Padding="8,6"
                                 BorderBrush="#CCCCCC" VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                        <Button Content="Load All Rates" Click="BtnLoadAll_Click"
                                Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Height="34"/>
                        <TextBlock x:Name="TxtStatus" VerticalAlignment="Center"
                                   Margin="16,0,0,0" Foreground="Gray"/>
                    </StackPanel>
                    <DataGrid x:Name="RatesGrid" Height="280"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" AlternatingRowBackground="#F0F4F8"
                              BorderBrush="#CCCCCC" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="*"/>
                            <DataGridTextColumn Header="Mid Rate (PLN)" Binding="{Binding Mid, StringFormat=F4}" Width="130"/>
                            <DataGridTextColumn Header="Effective Date" Binding="{Binding EffectiveDate, StringFormat=yyyy-MM-dd}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ── Historical Rates ──────────────────────────────────── -->
            <Border Background="White" CornerRadius="8" Padding="16"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Historical Rates" FontSize="14"
                               FontWeight="SemiBold" Foreground="#1E3A5F" Margin="0,0,0,10"/>

                    <!-- Inputs row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Currency code" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtHistCode" Width="80" Height="34" Padding="8,6"
                                     BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="From" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                            <DatePicker x:Name="DpFrom" Width="130" Height="34"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="To" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                            <DatePicker x:Name="DpTo" Width="130" Height="34"/>
                        </StackPanel>
                        <Button Content="Load" Click="BtnLoadHistory_Click"
                                Style="{StaticResource PrimaryButton}" Height="34" Margin="10,18,0,0"/>
                        <TextBlock x:Name="TxtHistStatus" VerticalAlignment="Center"
                                   Margin="16,0,0,0" Foreground="Gray"/>
                    </StackPanel>

                    <!-- Summary bar -->
                    <Border x:Name="HistSummary" Background="#F0F4F8" CornerRadius="4"
                            Padding="12,8" Margin="0,0,0,8" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Min: " Foreground="#1E3A5F" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtHistMin" Foreground="#1E3A5F" Margin="0,0,20,0"/>
                            <TextBlock Text="Max: " Foreground="#1E3A5F" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtHistMax" Foreground="#1E3A5F" Margin="0,0,20,0"/>
                            <TextBlock Text="Avg: " Foreground="#1E3A5F" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtHistAvg" Foreground="#1E3A5F"/>
                        </StackPanel>
                    </Border>

                    <!-- Results table -->
                    <DataGrid x:Name="HistGrid" Height="220"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" AlternatingRowBackground="#F0F4F8"
                              BorderBrush="#CCCCCC" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding EffectiveDate, StringFormat=yyyy-MM-dd}" Width="130"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="*"/>
                            <DataGridTextColumn Header="Mid Rate (PLN)" Binding="{Binding Mid, StringFormat=F4}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
