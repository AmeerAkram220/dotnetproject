<Page x:Class="ExchangeOfficeClient.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Login">
    <Grid Background="#F5F7FA">
        <Border Width="360" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="8" Padding="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.1" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Currency Exchange Office"
                           FontSize="16" FontWeight="Bold" Foreground="#1E3A5F"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Username" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUsername" Height="36" Padding="8,6"
                         BorderBrush="#CCCCCC" Margin="0,0,0,14"/>

                <TextBlock Text="Password" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" Height="36" Padding="8,6"
                             BorderBrush="#CCCCCC" Margin="0,0,0,20"/>

                <Button Content="Login" Click="BtnLogin_Click"
                        Style="{StaticResource PrimaryButton}" Height="38" Margin="0,0,0,10"/>
                <Button Content="Don't have an account? Register"
                        Click="BtnGoRegister_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#1E3A5F" Cursor="Hand"/>

                <TextBlock x:Name="TxtError" Foreground="Red" TextWrapping="Wrap"
                           Margin="0,12,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
